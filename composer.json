{
    "type": "symfony",
    "name": "olecarl/api",
    "description": "RESTful Web-API using Symfony with API-Platform",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": "^8.5",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "ext-pdo_sqlite": "*",
        "api-platform/doctrine-orm": "^4.3.3",
        "api-platform/hal": "^4.3.3",
        "api-platform/json-api": "^4.3.3",
        "api-platform/symfony": "^4.3.3",
        "doctrine/doctrine-bundle": "^3.2.2",
        "doctrine/doctrine-migrations-bundle": "^4.0",
        "doctrine/orm": "^3.6.2",
        "nelmio/cors-bundle": "^2.6.1",
        "phpdocumentor/reflection-docblock": "^6.0.3",
        "phpstan/phpdoc-parser": "^2.3.2",
        "stof/doctrine-extensions-bundle": "^1.15.3",
        "symfony/asset": "^8.0.6",
        "symfony/asset-mapper": "^8.0.6",
        "symfony/console": "^8.0.7",
        "symfony/dotenv": "^8.0.7",
        "symfony/expression-language": "^8.0.4",
        "symfony/flex": "^2.10",
        "symfony/framework-bundle": "^8.0.7",
        "symfony/monolog-bundle": "^4.0.1",
        "symfony/object-mapper": "^8.0.6",
        "symfony/property-access": "^8.0.4",
        "symfony/property-info": "^8.0.7",
        "symfony/requirements-checker": "^2.0.3",
        "symfony/runtime": "^8.0.1",
        "symfony/security-bundle": "^8.0.6",
        "symfony/serializer": "^8.0.7",
        "symfony/twig-bundle": "^8.0.4",
        "symfony/validator": "^8.0.7",
        "symfony/yaml": "^8.0.6",
        "webmozart/assert": "^2.1.6"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "bump-after-update": true,
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*"
    },
    "scripts": {
        "build": [
            "@prepare",
            "@lint",
            "@test"
        ],
        "prepare": [
            "composer validate --strict",
            "vendor/bin/php-cs-fixer fix"
        ],
        "lint": [
            "bin/console lint:container",
            "bin/console lint:twig"
        ],
        "test": [
            "vendor/bin/php-cs-fixer fix --dry-run --diff --verbose",
            "vendor/bin/phpstan analyse",
            "bin/console doctrine:schema:validate --skip-sync",
            "vendor/bin/codecept run --fail-fast"
        ],
        "report": [
            "vendor/bin/codecept run --html",
            "vendor/bin/phpmetrics --git --report-html=./build/phpmetrics/ ."
        ],
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd",
            "importmap:install": "symfony-cmd"
        },

        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "^8.0"
        }
    },
    "require-dev": {
        "codeception/codeception": "^5.3.5",
        "codeception/module-asserts": "^3.3.0",
        "codeception/module-doctrine": "^3.3",
        "codeception/module-phpbrowser": "^4.0",
        "codeception/module-rest": "^3.4.3",
        "codeception/module-symfony": "^3.8",
        "doctrine/doctrine-fixtures-bundle": "^4.3.1",
        "friendsofphp/php-cs-fixer": "^3.94.2",
        "phpmetrics/phpmetrics": "^2.9.1",
        "phpstan/phpstan": "^2.1.44",
        "phpunit/phpunit": "^12.5.14",
        "symfony/browser-kit": "^8.0.4",
        "symfony/css-selector": "^8.0.6",
        "symfony/maker-bundle": "^1.67.0",
        "symfony/panther": "^2.4",
        "symfony/stopwatch": "^v8.0",
        "symfony/web-profiler-bundle": "^8.0.7",
        "zenstruck/foundry": "^2.9.2"
    }
}
